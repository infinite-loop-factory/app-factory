# Copy this file to .env and fill in your own key.
# Obtain a serviceKey from https://data.kric.go.kr
# NEVER commit .env to the repository.
# If the key contains $ characters (e.g. bcrypt-format keys), wrap in single quotes
# to prevent dotenv from treating $ as a variable reference.
EXPO_PUBLIC_KRIC_SERVICE_KEY='your_service_key_here'

# Force localhost for Metro server URL (prevents simulator timeout via LAN IP)
# Remove or comment this out when testing on a real physical device (use LAN IP instead)
REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1
