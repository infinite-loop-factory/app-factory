{
  "name": "@infinite-loop-factory/snake-ladder",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://infinite-loop-factory.github.io/app-factory/",
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "i18n:build": "node scripts/build-locales.mjs",
    "ios": "expo run:ios",
    "ios:e2e": "EXPO_PUBLIC_E2E=1 EXPO_PUBLIC_E2E_GOLD_DICE=10 expo run:ios -d \"iPhone 17 Pro\"",
    "lint": "biome lint --fix --unsafe --no-errors-on-unmatched",
    "maestro": "maestro test .maestro/flows",
    "maestro:gold": "maestro test .maestro/flows/gold-dice.yaml",
    "maestro:screenshots": "maestro test .maestro/flows/screenshots.yaml",
    "maestro:settings": "maestro test .maestro/flows/settings.yaml",
    "maestro:smoke": "maestro test .maestro/flows/smoke.yaml",
    "screenshots:copy": "bash scripts/copy-epic-screenshots.sh",
    "sfx:build": "node scripts/generate-sfx.mts",
    "start": "expo start",
    "start:metro:e2e": "EXPO_PUBLIC_E2E=1 EXPO_PUBLIC_E2E_GOLD_DICE=10 expo start --port 8081",
    "pretest": "pnpm i18n:build",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll --passWithNoTests",
    "type-check": "tsc --noEmit",
    "web": "expo start --web",
    "web:publish": "tsx ../../scripts/web-publish.ts --app snake-ladder"
  },
  "dependencies": {
    "@expo-google-fonts/jua": "^0.4.1",
    "@expo/metro-runtime": "6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@gluestack-ui/core": "^3.0.12",
    "@gluestack-ui/utils": "^3.0.13",
    "@gluestack/ui-next-adapter": "^3.0.3",
    "@kirkelliott/ket": "^0.5.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.14",
    "ahooks": "^3.9.7",
    "clsx": "^2.1.1",
    "expo": "~54.0.34",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^4.3.1",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "i18n-js": "^4.5.1",
    "lucide-react-native": "catalog:",
    "nativewind": "catalog:",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "tailwindcss": "catalog:",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@biomejs/biome": "catalog:",
    "@infinite-loop-factory/config-typescript": "workspace:^",
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^18.3.1",
    "@types/three": "^0.184.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "type-fest": "catalog:",
    "typescript": "~5.9.2"
  }
}
